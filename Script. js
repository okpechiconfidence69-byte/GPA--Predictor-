function calculate() {
    let units = document.querySelectorAll('.units');
    let grades = document.querySelectorAll('.grade');
    
    let totalPoints = 0;
    let totalUnits = 0;

    for (let i = 0; i < units.length; i++) {
        let u = parseFloat(units[i].value) || 0;
        let g = parseFloat(grades[i].value);
        
        totalPoints += (u * g);
        totalUnits += u;
    }

    let gpa = totalUnits > 0 ? (totalPoints / totalUnits) : 0;
    document.getElementById('display').innerText = gpa.toFixed(2);
}